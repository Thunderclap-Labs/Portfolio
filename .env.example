# Site URL (used for sitemap, robots.txt, and Open Graph canonical URLs)
NEXT_PUBLIC_SITE_URL=https://thunderclaplabs.com

# Sanity CMS
# Get these values from your Sanity project at https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: for server-side draft preview (not required for basic use)
# SANITY_API_READ_TOKEN=your_read_token_here
